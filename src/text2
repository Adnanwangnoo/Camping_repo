// ── Global CSS Injection ──────────────────────────────────────────────
function injectCSS() {
  if (document.getElementById("aru-css")) return;
  const link = document.createElement("link");
  link.rel = "stylesheet";
  link.href = "https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700;900&display=swap";
  document.head.appendChild(link);

  const fa = document.createElement("link");
  fa.rel = "stylesheet";
  fa.href = "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css";
  document.head.appendChild(fa);

  const style = document.createElement("style");
  style.id = "aru-css";
  style.textContent = `
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: ${C.cream}; overflow-x: hidden; }
    .lift { transition: transform .22s, box-shadow .22s; }
    .lift:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(30,61,47,.13); }
    @media (max-width: 900px) { .section-padded { padding: 3rem 1.25rem !important; } }
  `;
  document.head.appendChild(style);
}

