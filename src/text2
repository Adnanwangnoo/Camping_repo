const Btn = ({ children, onClick, v = "primary", full }) => {
  const base = { fontFamily: "'Lato', sans-serif", fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", cursor: "pointer", border: "2px solid", padding: "0.8rem 1.9rem", width: full ? "100%" : "auto", fontSize: "0.78rem" };
  const styles = {
    primary: { ...base, background: C.forest, borderColor: C.forest, color: C.cream },
    outline: { ...base, background: "transparent", borderColor: C.forest, color: C.forest },
    gold: { ...base, background: C.gold, borderColor: C.gold, color: C.white }
